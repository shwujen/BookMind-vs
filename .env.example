# Express Backend Port
PORT=5000

# Google Apps Script Web App Deployment URL for Express backend
GOOGLE_APP_SCRIPT_URL=https://your-google-apps-script-url/exec

# Google Apps Script Web App URL for front-end static deployment (GitHub Pages)
# This must ALSO be set as a GitHub repository secret named VITE_GAS_URL
VITE_GAS_URL=https://your-google-apps-script-url/exec
